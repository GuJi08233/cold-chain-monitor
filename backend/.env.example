APP_NAME=Cold Chain Backend
APP_ENV=prod
APP_DEBUG=false
APP_HOST=0.0.0.0
APP_PORT=8000
APP_SECRET_KEY=replace-with-64-char-random-secret
JWT_SECRET_KEY=replace-with-jwt-signing-secret
JWT_EXPIRE_MINUTES=1440
DATABASE_URL=sqlite:///./data/cold_chain.db
SQL_ECHO=false
SUPER_ADMIN_USERNAME=admin
SUPER_ADMIN_PASSWORD=replace-with-strong-admin-password
CORS_ORIGINS=http://localhost:5173,https://app.example.com
MQTT_BROKER=replace-with-mqtt-host
MQTT_PORT=1883
MQTT_USERNAME=replace-with-mqtt-username
MQTT_PASSWORD=replace-with-mqtt-password
MQTT_TOPIC=esp32/data
MQTT_CLIENT_ID=cold_chain_server
TDENGINE_HOST=replace-with-tdengine-host
TDENGINE_NATIVE_PORT=6030
TDENGINE_REST_PORT=6041
TDENGINE_USERNAME=replace-with-tdengine-username
TDENGINE_PASSWORD=replace-with-tdengine-password
TDENGINE_DB=cold_chain
ETH_RPC_URL=https://your-evm-rpc.example
ETH_CONTRACT_ADDRESS=replace-with-contract-address
ETH_PRIVATE_KEY=replace-with-private-key
ETH_AES_KEY=replace-with-32-byte-aes-key
