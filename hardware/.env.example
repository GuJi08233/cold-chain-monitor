# 该文件仅用于记录硬件示例配置项，ESP32 草图不会自动读取 .env。
# 请将以下占位值手动同步到本地的 esp32.ino 或其他私有配置头文件中。

WIFI_SSID=YOUR_WIFI_SSID
WIFI_PASSWORD=YOUR_WIFI_PASSWORD

MQTT_SERVER=YOUR_MQTT_BROKER_HOST
MQTT_PORT=1883
MQTT_USER=YOUR_MQTT_USERNAME
MQTT_PASSWORD=YOUR_MQTT_PASSWORD
MQTT_CLIENT_ID=esp32-client-demo

TOPIC_PUBLISH=esp32/data

NTP_SERVER1=ntp.aliyun.com
NTP_SERVER2=pool.ntp.org
GMT_OFFSET_SEC=28800
DAYLIGHT_OFFSET_SEC=0
